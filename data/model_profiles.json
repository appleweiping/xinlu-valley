    "key_env": "LOCAL_OPENAI_API_KEY",
    "base_url_env": "LOCAL_OPENAI_BASE_URL",
    "default_base_url": "http://127.0.0.1:8001/v1",
    "models": ["configured-by-proxy"],
    "safety": "no-secret-display"
