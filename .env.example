# AI Town local model/API configuration template
#
# Copy values into your local environment or a private .env file.
# Do not commit real API keys.

DEEPSEEK_API_KEY=replace-with-your-private-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

OPENAI_API_KEY=replace-with-your-private-key
OPENAI_BASE_URL=https://api.openai.com

ANTHROPIC_API_KEY=replace-with-your-private-key
ANTHROPIC_BASE_URL=https://api.anthropic.com

GEMINI_API_KEY=replace-with-your-private-key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

LOCAL_OPENAI_API_KEY=replace-with-your-private-key-or-local-token
LOCAL_OPENAI_BASE_URL=http://127.0.0.1:8001/v1
